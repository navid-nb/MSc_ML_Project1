erDiagram
    %% === CORE ENTITIES ===
    CRSP_DSF {
      int PERMNO PK
      date DATE PK
      float PRC
      float RET
      float VOL
      int SHROUT
    }

    CRSP_STOCKNAMES {
      int PERMNO PK
      string TICKER
      string NCUSIP
      date NAMEDT
      date NAMEENDDT
    }

    CRSP_CCMXPF_LINKTABLE {
      int PERMNO PK
      string GVKEY PK
      string LINKTYPE
      string LINKPRIM
      date LINKDT
      date LINKENDDT
    }

    CRSP_DSEDELIST {
      int PERMNO
      date DLSTDT
      float DLRET
      string DLSTCD
    }

    CRSP_STKDISTRIBUTIONS {
      int PERMNO
      date DCLRDT
      date EXDATE
      string DISTCD
      float DIVAMT
      float FACPR
    }

    COMP_FUNDQ {
      string GVKEY PK
      date DATADATE PK
      int FYR
      int FQTR
      float AT
      float LT
      float SALE
      float NI
%%      /* many fundamentals ... */
    }

    COMP_FUNDA {
      string GVKEY PK
      date DATADATE PK
      int FYR
      float AT
      float LT
      float SALE
      float NI
    }

    COMP_COMPANY {
      string GVKEY PK
      string CONM
      string TIC
      string CIK
      string SIC
    }

    COMP_SECD {
      string GVKEY PK
      string IID PK
      date SDATE
      date EDATE
      string TIC
      string CUSIP
    }

    FF_FACTORS_DAILY {
      date DATE PK
      float MKT_RF
      float SMB
      float HML
      float MOM
      float RF
    }

    IBES_ID {
      string TICKER PK
      string CUSIP
      string GVKEY
      int PERMNO
      string USFIRM
    }

    IBES_STATSUMU_EPSUS {
      string TICKER PK
      date STATPERS PK
      date ANNDATS_ACT
      time ANNDTIME
      float MEANEST
      int NUMEST
      float STDEV
      string FPI
    }

    IBES_ACTU_EPSUS {
      string TICKER PK
      date ANNDATS_ACT PK
      time ANNDTIME
      float ACTUAL
      string FPI
      date FPEDATS
    }

    FEATURE_MATRIX {
      int PERMNO PK
      string GVKEY
      date DATE PK
%%      /* engineered features & targets */
    }

    %% === RELATIONSHIPS ===
    CRSP_DSF ||--o{ CRSP_STOCKNAMES : "PERMNO & DATE∈[NAMEDT,NAMEENDDT]"
    CRSP_DSF ||--o{ CRSP_CCMXPF_LINKTABLE : "PERMNO & DATE∈[LINKDT,LINKENDDT]"
    CRSP_DSF ||--o{ CRSP_DSEDELIST : "PERMNO→DLSTDT (event)"
    CRSP_DSF ||--o{ CRSP_STKDISTRIBUTIONS : "PERMNO→EXDATE (events)"
    CRSP_CCMXPF_LINKTABLE }o--|| COMP_COMPANY : "GVKEY"
    CRSP_CCMXPF_LINKTABLE }o--o{ COMP_FUNDQ : "GVKEY & lag(DATADATE) ≤ DATE"
    CRSP_CCMXPF_LINKTABLE }o--o{ COMP_FUNDA : "GVKEY & lag(DATADATE) ≤ DATE"
    CRSP_CCMXPF_LINKTABLE }o--o{ COMP_SECD : "GVKEY & DATE∈[SDATE,EDATE]"
    CRSP_DSF ||--|| FF_FACTORS_DAILY : "DATE"
    IBES_ID }o--o{ CRSP_DSF : "PERMNO or CUSIP/TICKER bridge"
    IBES_ID }o--o{ CRSP_CCMXPF_LINKTABLE : "GVKEY (when present)"
    IBES_ID ||--o{ IBES_STATSUMU_EPSUS : "TICKER"
    IBES_ID ||--o{ IBES_ACTU_EPSUS : "TICKER"
    IBES_STATSUMU_EPSUS }o--o{ IBES_ACTU_EPSUS : "FPI/period alignment"
    CRSP_DSF ||--|| FEATURE_MATRIX : "PERMNO, DATE"
    CRSP_CCMXPF_LINKTABLE ||--|| FEATURE_MATRIX : "GVKEY (via PERMNO+DATE)"
    FF_FACTORS_DAILY ||--|| FEATURE_MATRIX : "DATE"
    COMP_FUNDQ }o--|| FEATURE_MATRIX : "lagged join on GVKEY"
    COMP_FUNDA }o--|| FEATURE_MATRIX : "lagged join on GVKEY"
    IBES_STATSUMU_EPSUS }o--|| FEATURE_MATRIX : "pre-ann consensus before ANNDATS_ACT"
    IBES_ACTU_EPSUS }o--|| FEATURE_MATRIX : "SUE using ACTUAL vs prior consensus"
    CRSP_STKDISTRIBUTIONS }o--|| FEATURE_MATRIX : "div/split flags"
    CRSP_DSEDELIST }o--|| FEATURE_MATRIX : "delist return handling"