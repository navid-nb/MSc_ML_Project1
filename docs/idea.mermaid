%% mmdc -i docs/idea.mermaid -o docs/idea.svg
flowchart TD
  %% ===== L1: DATA & FEATURES =====
  A["Market & Fundamentals Data<br/>- OHLCV, corporate actions<br/>- Spreads/slippage proxies<br/>- Lagged fundamentals (WRDS)<br/>- Calendar/regime flags"]
  B["Feature Builder X_t<br/>- Shift by true availability (no leakage)<br/>- Rolling stats, tech indicators<br/>- Standardize for glmnet"]

  A --> B

  %% ===== L2: MODEL FAMILY =====
  subgraph M["Models (per horizon n∈{1,5,20})"]
    direction TB
    M1["OLS / MLR (Ch.3)<br/>β̂=(XᵀX)⁻¹Xᵀy; HAC coefs (optional)"]
    M2["Regularization (Ch.6)<br/>Ridge/Lasso/EN via glmnet"]
    M3["Subset Selection (Ch.6)<br/>Exhaustive/Forward/Backward (leaps)"]
  end
  B --> M

  %% ===== CV / SELECTION =====
  subgraph CV["Model Selection (Ch.5 & Ch.6)"]
    direction TB
    C1["LOOCV / 10-fold (Ch.5)"]
    C2["TimeSlice: Expanding & Sliding (Ch.5)"]
    C3["Grid over (α,λ) for glmnet (Ch.6)"]
    C4["Pick by RMSE / R² / BIC / AdjR²"]
  end
  M --> CV

  %% ===== PREDICTIONS =====
  P["Predictions per horizon<br/>μ_n(t): expected return<br/>σ_n(t): uncertainty/quantiles"]
  CV --> P

  %% ===== COSTS & DECISION =====
  E["Cost Model c(t)<br/>Commission, spread/slippage, borrow"]
  D["Utility (Eq. 1)<br/>U_n(t)=|μ_n(t)| - c(t) - κ·σ_n(t)"]
  P --> D
  E --> D

  Q{"max_n U_n(t) > 0 ?"}
  D --> Q
  Q -- "No" --> Z0["No Trade"]
  Q -- "Yes" --> Nstar["Choose best horizon n* and side = sign(μ_{n*}(t))"]

  %% ===== SIZING =====
  S["Sizing (Eq. 2)<br/>S_t = clip( β·μ_{n*}(t)/σ_{n*}(t), -S_max, S_max )"]
  Nstar --> S

  %% ===== RISK & ORDERS =====
  R1{"Risk gates<br/>- Turnover/exposure caps"}
  S --> R1
  R1 -- "No" --> Z0
  R1 -- "Yes" --> O["Orders<br/>Side, size, timing (next close/open)"]

  %% ===== EXECUTION & EXITS =====
  X["Execution w/ slippage"]
  O --> X
  EXIT["Exits<br/>Time stop at t+n*<br/>Vol-scaled stop-loss<br/>Take-profit"]
  X --> EXIT

  %% ===== PORTFOLIOS =====
  subgraph PF["Portfolio Layer"]
    direction TB
    W0["Equal-Weight baseline"]
    W1["Mean-Variance (μ,Σ from train)"]
    W2["Max-Diversification"]
    W3["Picking Long–Short (Ch.3/Ch.6)<br/>Long top-k, Short bottom-k<br/>Weights: +2/k vs −1/k"]
  end
  EXIT --> PF

  %% ===== ACCOUNTING & REPORTS =====
  ACC["Accounting & Blotter<br/>P&L = price change×size − costs"]
  PF --> ACC

  REP["Reports<br/>Cumulative return, Sharpe, ES<br/>DD, turnover, hit rate<br/>Calibration & cost breakdown"]
  ACC --> REP

  %% ===== FEEDBACK =====
  REP -.-> CV